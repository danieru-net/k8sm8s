---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { GITHUB_REPO_URL, SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const techArticles = (await getCollection('tech')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const wellnessArticles = (await getCollection('wellness')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <!-- Background grid -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(rgba(50,108,229,1) 1px, transparent 1px), linear-gradient(90deg, rgba(50,108,229,1) 1px, transparent 1px); background-size: 40px 40px;"
      aria-hidden="true"
    >
    </div>
    <!-- Glow -->
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-k8s-blue/10 rounded-full blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">
      <div
        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-k8s-blue/10 border border-k8s-blue/20 text-k8s-blue-light text-xs font-medium mb-6"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-k8s-cyan animate-pulse"></span>
        Community-driven · Open source · Free forever
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-50 leading-tight mb-6">
        Kubernetes engineering
        <br />
        <span class="text-k8s-blue">meets human sustainability</span>
      </h1>

      <p class="text-lg sm:text-xl text-slate-400 leading-relaxed max-w-2xl mx-auto mb-10">
        Deep-dive technical content and honest wellness resources for the engineers who keep the
        cluster — and themselves — running.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/tech"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-k8s-blue text-white font-semibold hover:bg-k8s-blue-dark transition-colors shadow-lg shadow-blue-500/20"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          Explore Technical Articles
        </a>
        <a
          href="/wellness"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-emerald-600/20 text-emerald-400 font-semibold border border-emerald-600/30 hover:bg-emerald-600/30 hover:text-emerald-300 transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
            ></path>
          </svg>
          Explore Wellness Articles
        </a>
        <a
          href={`${GITHUB_REPO_URL}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-surface-elevated text-slate-300 font-semibold border border-surface-border hover:text-white hover:border-slate-600 transition-colors"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
          </svg>
          Submit an Article
        </a>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <section class="border-b border-surface-border bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5">
      <div class="flex flex-wrap justify-center sm:justify-between gap-6 text-center sm:text-left">
        <div>
          <span class="block text-2xl font-bold text-k8s-blue">{techArticles.length}</span>
          <span class="text-xs text-slate-500 uppercase tracking-wide">Technical Articles</span>
        </div>
        <div>
          <span class="block text-2xl font-bold text-emerald-400">{wellnessArticles.length}</span>
          <span class="text-xs text-slate-500 uppercase tracking-wide">Wellness Articles</span>
        </div>
        <div>
          <span class="block text-2xl font-bold text-k8s-cyan">100%</span>
          <span class="text-xs text-slate-500 uppercase tracking-wide">Community written</span>
        </div>
        <div>
          <span class="block text-2xl font-bold text-violet-400">Open</span>
          <span class="text-xs text-slate-500 uppercase tracking-wide">Source &amp; CC BY 4.0</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Recent Technical Articles -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-slate-100">Technical Articles</h2>
        <p class="text-sm text-slate-500 mt-1">
          Deep dives into Kubernetes, networking, security, and platform engineering.
        </p>
      </div>
      <a
        href="/tech"
        class="text-sm text-k8s-blue-light hover:text-white transition-colors flex items-center gap-1"
      >
        View all
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        techArticles
          .slice(0, 3)
          .map((article) => (
            <ArticleCard
              slug={article.id}
              title={article.data.title}
              description={article.data.description}
              publishDate={article.data.publishDate}
              type="tech"
              tags={article.data.tags}
              author={article.data.author}
            />
          ))
      }
    </div>
  </section>

  <!-- Recent Wellness Articles -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-slate-100">Wellness Articles</h2>
        <p class="text-sm text-slate-500 mt-1">
          Mental health, physical wellbeing, and sustainable engineering culture.
        </p>
      </div>
      <a
        href="/wellness"
        class="text-sm text-emerald-400 hover:text-white transition-colors flex items-center gap-1"
      >
        View all
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        wellnessArticles
          .slice(0, 3)
          .map((article) => (
            <ArticleCard
              slug={article.id}
              title={article.data.title}
              description={article.data.description}
              publishDate={article.data.publishDate}
              type="wellness"
              category={article.data.category}
              author={article.data.author}
              readingTime={article.data.readingTime}
            />
          ))
      }
    </div>
  </section>

  <!-- Contribute CTA -->
  <section class="border-t border-surface-border bg-surface">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 mb-4">Write for the community</h2>
      <p class="text-slate-400 leading-relaxed mb-8 max-w-xl mx-auto">
        All content is contributed via pull request. If you have deep knowledge in Kubernetes, SRE
        practices, or engineering wellness — this is your platform.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={`${GITHUB_REPO_URL}/blob/main/README.md`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-k8s-blue text-white font-medium hover:bg-k8s-blue-dark transition-colors"
        >
          Read the Contribution Guide
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
