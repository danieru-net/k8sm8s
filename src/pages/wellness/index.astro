---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FilterSystem from '../../components/FilterSystem';
import { getCollection } from 'astro:content';
import type { FilterableArticle, FilterOption } from '../../components/FilterSystem';

const articles = (await getCollection('wellness')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const filterableArticles: FilterableArticle[] = articles.map((a) => ({
  slug: a.id,
  title: a.data.title,
  description: a.data.description,
  publishDate: a.data.publishDate.toISOString(),
  type: 'wellness' as const,
  category: a.data.category,
  author: a.data.author,
  readingTime: a.data.readingTime,
}));

// Category filters for wellness
const filters: FilterOption[] = [
  { label: '🧠 Mental', value: 'Mental' },
  { label: '💪 Physical', value: 'Physical' },
  { label: '🔥 Burnout', value: 'Burnout' },
];
---

<BaseLayout
  title="Wellness Articles"
  description="Mental health, physical wellbeing, burnout prevention, and sustainable engineering culture for Kubernetes and SRE practitioners."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page header -->
    <header class="mb-12">
      <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
        <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
        <span>/</span>
        <span class="text-slate-400">Wellness</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-50 mb-3">Wellness Articles</h1>
      <p class="text-lg text-slate-400 max-w-2xl">
        Honest, practitioner-authored resources on mental health, burnout, physical wellness, and
        sustainable engineering culture. WCAG AA compliant for readability.
      </p>

      <!-- Accessibility note -->
      <div
        class="mt-4 inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-emerald-500/10 border border-emerald-500/20 text-emerald-300 text-xs"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        WCAG AA compliant — optimized for readability
      </div>
    </header>

    <!-- Filter + articles (React island) -->
    <FilterSystem client:load articles={filterableArticles} filters={filters} type="wellness" />
  </div>
</BaseLayout>
