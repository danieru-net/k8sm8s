---
interface Props {
  slug: string;
  title: string;
  description: string;
  publishDate: Date;
  type: 'tech' | 'wellness';
  tags?: string[];
  category?: string;
  author: string;
  readingTime?: number;
}

const { slug, title, description, publishDate, type, tags, category, author, readingTime } =
  Astro.props;

const href = `/${type}/${slug}`;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryClasses: Record<string, string> = {
  Mental: 'bg-violet-500/10 text-violet-300 border-violet-500/20',
  Physical: 'bg-emerald-500/10 text-emerald-300 border-emerald-500/20',
  Burnout: 'bg-amber-500/10 text-amber-300 border-amber-500/20',
};
---

<a
  href={href}
  class="group flex flex-col bg-surface hover:bg-surface-elevated border border-surface-border hover:border-slate-600 rounded-xl p-6 transition-all duration-200"
>
  <!-- Date + category badge -->
  <div class="flex items-start justify-between gap-3 mb-3">
    <time datetime={publishDate.toISOString()} class="text-xs text-slate-500">{formattedDate}</time>
    {
      category && (
        <span
          class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border shrink-0 ${
            categoryClasses[category] ?? 'bg-slate-700 text-slate-300 border-slate-600'
          }`}
        >
          {category}
        </span>
      )
    }
  </div>

  <!-- Title -->
  <h3 class="text-base font-semibold text-slate-100 group-hover:text-white leading-snug mb-2 line-clamp-2">
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-slate-400 leading-relaxed mb-4 line-clamp-3 flex-1">
    {description}
  </p>

  <!-- Footer: tags + reading time -->
  <div class="flex items-center justify-between mt-auto pt-4 border-t border-surface-border">
    <div class="flex flex-wrap gap-1.5">
      {
        tags?.slice(0, 3).map((tag) => (
          <span class="tag-pill">{tag}</span>
        ))
      }
    </div>
    <div class="flex items-center gap-3 shrink-0 ml-2">
      {readingTime && <span class="text-xs text-slate-600">{readingTime} min</span>}
      <span class="text-xs text-slate-600">@{author}</span>
    </div>
  </div>
</a>
