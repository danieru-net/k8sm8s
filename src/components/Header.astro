---
import Search from './Search';
import { getCollection } from 'astro:content';
import type { SearchItem } from './Search';

const techArticles = await getCollection('tech');
const wellnessArticles = await getCollection('wellness');

const searchItems: SearchItem[] = [
  ...techArticles.map((a) => ({
    title: a.data.title,
    description: a.data.description,
    slug: a.slug,
    type: 'tech' as const,
    tags: a.data.tags,
  })),
  ...wellnessArticles.map((a) => ({
    title: a.data.title,
    description: a.data.description,
    slug: a.slug,
    type: 'wellness' as const,
    category: a.data.category,
  })),
];

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/tech', label: 'Technical' },
  { href: '/wellness', label: 'Wellness' },
];
---

<header class="sticky top-0 z-40 border-b border-surface-border bg-surface-dark/80 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="k8sm8s home">
        <!-- K8s wheel SVG -->
        <svg
          class="w-8 h-8 text-k8s-blue group-hover:text-k8s-blue-light transition-colors"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"
          />
          <circle cx="12" cy="12" r="2" />
          <path d="M12 6v2M12 16v2M6 12h2M16 12h2M7.76 7.76l1.42 1.42M14.82 14.82l1.42 1.42M7.76 16.24l1.42-1.42M14.82 9.18l1.42-1.42" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        </svg>
        <span class="font-bold text-lg tracking-tight text-slate-100 group-hover:text-white transition-colors">
          k8sm8s
        </span>
      </a>

      <!-- Nav + Search -->
      <div class="flex items-center gap-1 sm:gap-2">
        <nav class="hidden sm:flex items-center gap-1" aria-label="Main navigation">
          {
            navLinks.map((link) => {
              const isActive = currentPath.startsWith(link.href);
              return (
                <a
                  href={link.href}
                  class={`px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
                    isActive
                      ? 'bg-surface text-slate-100'
                      : 'text-slate-400 hover:text-slate-200 hover:bg-surface/60'
                  }`}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {link.label}
                </a>
              );
            })
          }
        </nav>

        <!-- Search island -->
        <Search client:load items={searchItems} />

        <!-- GitHub link -->
        <a
          href="https://github.com/k8sm8s/k8sm8s"
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-slate-500 hover:text-slate-200 hover:bg-surface transition-colors"
          aria-label="View on GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"
            />
          </svg>
        </a>

        <!-- Mobile nav toggle -->
        <button
          id="mobile-menu-btn"
          class="sm:hidden p-2 rounded-lg text-slate-500 hover:text-slate-200 hover:bg-surface transition-colors"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <nav
      id="mobile-menu"
      class="sm:hidden hidden pb-4 border-t border-surface-border pt-3"
      aria-label="Mobile navigation"
    >
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-slate-200 hover:bg-surface transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
