---
import BaseLayout from './BaseLayout.astro';
import GiscusComments from '../components/GiscusComments';
import {
  GITHUB_REPO_URL,
  GITHUB_DEFAULT_BRANCH,
  GISCUS_REPO,
  GISCUS_REPO_ID,
  GISCUS_CATEGORY,
  GISCUS_CATEGORY_ID,
} from '../consts';

interface Props {
  title: string;
  description: string;
  author: string;
  publishDate: Date;
  tags?: string[];
  category?: 'Mental' | 'Physical' | 'Burnout';
  readingTime?: number;
  contentPath: string;
  type: 'tech' | 'wellness';
}

const {
  title,
  description,
  author,
  publishDate,
  tags,
  category,
  readingTime,
  contentPath,
  type,
} = Astro.props;

const editUrl = `${GITHUB_REPO_URL}/edit/${GITHUB_DEFAULT_BRANCH}/src/content/${contentPath}`;
const submitTechUrl = `${GITHUB_REPO_URL}/new/${GITHUB_DEFAULT_BRANCH}/src/content/tech`;
const submitWellnessUrl = `${GITHUB_REPO_URL}/new/${GITHUB_DEFAULT_BRANCH}/src/content/wellness`;

const categoryClasses: Record<string, string> = {
  Mental: 'tag-pill-mental',
  Physical: 'tag-pill-physical',
  Burnout: 'tag-pill-burnout',
};

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 lg:py-16">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8" aria-label="Breadcrumb">
      <a href="/" class="hover:text-slate-300 transition-colors">Home</a>
      <span>/</span>
      <a href={`/${type}`} class="hover:text-slate-300 transition-colors capitalize">{type}</a>
      <span>/</span>
      <span class="text-slate-400 truncate">{title}</span>
    </nav>

    <!-- Article Header -->
    <header class="mb-10">
      <!-- Type badge -->
      <div class="flex items-center gap-3 mb-4">
        {
          type === 'tech' ? (
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold tracking-wide uppercase px-3 py-1 rounded-full bg-k8s-blue/10 text-k8s-blue-light border border-k8s-blue/20">
              <span>⚙</span> Technical
            </span>
          ) : (
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold tracking-wide uppercase px-3 py-1 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
              <span>🌱</span> Wellness
            </span>
          )
        }
        {category && <span class={categoryClasses[category]}>{category}</span>}
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold text-slate-50 leading-tight mb-4">
        {title}
      </h1>

      <p class="text-lg text-slate-400 leading-relaxed mb-6">{description}</p>

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500 pb-6 border-b border-surface-border">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          <a
            href={`https://github.com/${author}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-k8s-blue-light transition-colors"
          >
            @{author}
          </a>
        </span>
        <time datetime={publishDate.toISOString()} class="flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {formattedDate}
        </time>
        {
          readingTime && (
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {readingTime} min read
            </span>
          )
        }
      </div>

      <!-- Tags -->
      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <!-- Article Body -->
    <div class="prose prose-invert prose-slate max-w-none prose-headings:font-semibold prose-a:text-sky-400 prose-a:no-underline hover:prose-a:underline prose-code:font-mono">
      <slot />
    </div>

    <!-- Contribution CTA -->
    <aside class="mt-16 p-6 rounded-xl bg-surface border border-surface-border">
      <h2 class="text-base font-semibold text-slate-200 mb-1">Found something to improve?</h2>
      <p class="text-sm text-slate-400 mb-4">
        This article is community-maintained. Corrections, additions, and updates are welcome via pull request.
      </p>
      <div class="flex flex-wrap gap-3">
        <a
          href={editUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-k8s-blue text-white hover:bg-k8s-blue-dark transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
          </svg>
          Edit this page
        </a>
        <a
          href={type === 'tech' ? submitTechUrl : submitWellnessUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-surface-elevated text-slate-300 border border-surface-border hover:text-slate-100 hover:border-slate-600 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Submit an article
        </a>
      </div>
    </aside>

    <!-- Comments -->
    <section class="mt-12">
      <h2 class="text-xl font-semibold text-slate-200 mb-6">Discussion</h2>
      <GiscusComments
        client:load
        repo={GISCUS_REPO}
        repoId={GISCUS_REPO_ID}
        category={GISCUS_CATEGORY}
        categoryId={GISCUS_CATEGORY_ID}
      />
    </section>
  </article>
</BaseLayout>
